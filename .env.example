# SafeFlow OS environment variables

# App
# APP_URL: The URL where this app is hosted.
# AI Studio may inject this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:8000"

# AI providers
# Backend agents currently use GROQ_API_KEY.
GROQ_API_KEY="your_groq_api_key"
GROQ_SUMMARY_MODEL="llama-3.3-70b-versatile"
GEMINI_API_KEY="your_gemini_api_key_if_used"

# Supabase project
# Frontend-safe values. The anon key is public but protected by RLS policies.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Backend-only values. Never expose service role keys in frontend code.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_JWT_SECRET="your_supabase_jwt_secret_optional"

# Supabase Storage
SUPABASE_STORAGE_BUCKET="schedule-documents"

# Optional Supabase Storage S3-compatible API.
# Needed only if backend scripts/tools upload through S3 clients instead of supabase-js/supabase-py.
SUPABASE_S3_ENDPOINT="https://your-project-ref.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="your-project-region"
SUPABASE_S3_ACCESS_KEY_ID="your_supabase_s3_access_key_id"
SUPABASE_S3_SECRET_ACCESS_KEY="your_supabase_s3_secret_access_key"
SUPABASE_S3_BUCKET="schedule-documents"

# Optional direct database connection for migrations/scripts.
# Use the pooled connection string from Supabase Project Settings > Database.
SUPABASE_DB_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres"
